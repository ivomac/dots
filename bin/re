#!/usr/bin/env bash

time="1s"
while getopts t: opt; do
  case $opt in
  t)
    time="$OPTARG"
    ;;
  esac
done
shift "$((OPTIND - 1))"

home_pos=$(tput cup 0 0)
ED=$(tput ed)
EL=$(tput el)
printf '%s%s' "$home_pos" "$ED"
while true; do
  ROWS=$(tput lines)
  COLS=$(tput cols)
  CMD="$@"
  ${SHELL:=sh} -c "$CMD" | head -n $ROWS | while IFS= read LINE; do
    printf '%-*.*s%s\n' $COLS $COLS "$LINE" "$EL"
  done
  printf '%s%s' "$ED" "$home_pos"
  sleep "$time"
done
