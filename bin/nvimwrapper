#!/usr/bin/env bash

cmd=""
if [[ "${1}" =~ ^\+ ]]; then
  cmd="${1#+}"
  shift
fi

files=("${@}")

if [[ -z "$TMUX" ]] || [[ "${files[*]}" =~ /tmp/ ]]; then
  exec nvim ${cmd:+"+$cmd"} "${files[@]}"
fi

addr=$(tmux show-environment NVIM_SERVER 2>/dev/null | cut -d= -f2)

if [[ -z "$addr" || ! -S "$addr" ]]; then
  exec nvim ${cmd:+"+$cmd"} "${files[@]}"
fi

nvim --server "$addr" --remote-silent "${files[@]}"

if [[ -n "$cmd" ]]; then
  nvim --server "$addr" --remote-send "<C-\\><C-N>:${cmd}<CR>"
fi

tmux select-window -t ':=nvim'
