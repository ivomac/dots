#!/usr/bin/env bash

swayidle -w \
  timeout 10 'if pgrep swaylock; then niri msg action power-off-monitors; fi' \
  resume 'if pgrep swaylock; then niri msg action power-on-monitors; fi' &

wallpaper=$(awww query 2>/dev/null | sed -n 's/.*currently displaying: image: //p' | head -1)

niri msg action power-off-monitors
sleep 0.1s
swaylock -i "$wallpaper"

kill %%
