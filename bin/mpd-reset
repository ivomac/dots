#!/usr/bin/env bash

mkdir -p "$XDG_CACHE_HOME/mpd/playlists"

MAX_WAIT=60
WAITED=0

while ! pgrep mpd >/dev/null; do
  sleep 2
  WAITED=$((WAITED + 2))
  [[ $WAITED -ge $MAX_WAIT ]] && break
done

if [[ -z "$(mpc current)" ]]; then
  mpc clear
  mpc add /
  mpc shuffle
fi

mpc random off
mpc consume on
mpc crossfade 2

mpc play 1
mpc stop
