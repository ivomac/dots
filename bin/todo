#!/usr/bin/env python

import subprocess as sp
import sys
from datetime import datetime, timezone
from uuid import uuid4

import pyperclip as clip
import requests

TURSO_URL_PATH = "website/ivomac.github.io/todo-webapp/db_url"
TURSO_TOKEN_PATH = "website/ivomac.github.io/todo-webapp/auth_token"
TABLE = sys.argv[1] if len(sys.argv) > 1 else "todo"
MENU = [
    "fzf",
    "--bind=enter:accept-or-print-query",
    "--exact",
    "--input-label",
    " TODO ",
]

URL = (
    sp.check_output(["pass", "show", TURSO_URL_PATH], text=True)
    .rstrip("\n")
    .replace("libsql://", "https://")
)
TOKEN = sp.check_output(["pass", "show", TURSO_TOKEN_PATH], text=True).rstrip("\n")


def to_arg(val):
    if val is None:
        return {"type": "null"}
    return {"type": "text", "value": str(val)}


def pipeline(statements):
    body = [
        {"type": "execute", "stmt": {"sql": sql, "args": [to_arg(a) for a in args]}}
        for sql, args in statements
    ] + [{"type": "close"}]
    resp = requests.post(
        f"{URL}/v2/pipeline",
        headers={"Authorization": f"Bearer {TOKEN}"},
        json={"requests": body},
        timeout=3,
    )
    resp.raise_for_status()
    results = resp.json()["results"]
    for result in results:
        if result["type"] == "error":
            raise RuntimeError(f"SQL error: {result['error']['message']}")
    r = results[0]["response"]["result"]
    cols = [c["name"] for c in r["cols"]]
    return [dict(zip(cols, [v["value"] for v in row])) for row in r["rows"]]


def fetch_active():
    return pipeline(
        [
            (
                f'SELECT id, content FROM "{TABLE}" WHERE done_at IS NULL ORDER BY created_at DESC',
                [],
            ),
        ]
    )


def main():
    id_by_content = {t["content"]: t["id"] for t in fetch_active()}
    to_add = []
    to_done = []
    while True:
        try:
            out = sp.check_output(MENU, input="\n".join(id_by_content), text=True).rstrip("\n")
        except sp.CalledProcessError:
            break
        if out in id_by_content:
            to_done.append(id_by_content.pop(out))
            clip.copy(out)
        else:
            item_id = str(uuid4())
            created_at = datetime.now(timezone.utc).isoformat()
            to_add.append((item_id, out, created_at))
            id_by_content = {out: item_id, **id_by_content}
    if not to_add and not to_done:
        return
    now = datetime.now(timezone.utc).isoformat()
    statements = [
        (
            f'INSERT INTO "{TABLE}" (id, content, created_at) VALUES (?, ?, ?)',
            [item_id, content, created_at],
        )
        for item_id, content, created_at in to_add
    ] + [(f'UPDATE "{TABLE}" SET done_at = ? WHERE id = ?', [now, item_id]) for item_id in to_done]
    pipeline(statements)


if __name__ == "__main__":
    main()
