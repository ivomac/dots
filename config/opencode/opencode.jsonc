{
  "$schema": "https://opencode.ai/config.json",
  "model": "deepseek/deepseek-v4-pro",
  "small_model": "deepseek/deepseek-v4-flash",
  "default_agent": "plan",
  "autoupdate": false,
  "share": "manual",
  "snapshot": false,
  "username": "Ivo",
  "disabled_providers": [],
  "permission": {
    "read": {
      "**/*.ipynb": "deny"
    },
    "bash": {
      "*": "ask",
      "ls": "allow",
      "ls *": "allow",
      "awk": "allow",
      "awk *": "allow",
      "find": "allow",
      "find *": "allow",
      "fd": "allow",
      "fd *": "allow",
      "grep": "allow",
      "grep *": "allow",
      "rg": "allow",
      "rg *": "allow",
      "echo": "allow",
      "echo *": "allow",
      "head": "allow",
      "head *": "allow",
      "tail": "allow",
      "tail *": "allow",
      "sort": "allow",
      "sort *": "allow",
      "mkdir": "allow",
      "mkdir *": "allow",
      "wc": "allow",
      "wc *": "allow",
      "tr": "allow",
      "tr *": "allow",
      "sed": "allow",
      "sed *": "allow",
      "stat": "allow",
      "stat *": "allow",
      "jq": "allow",
      "jq *": "allow",
      "du": "allow",
      "du *": "allow",
      "git log": "allow",
      "git log *": "allow",
      "nb": "allow",
      "nb pull *": "allow",
      "nb push *": "allow",
      "nb outputs *": "allow",
      "nb run *": "ask",
      "jupytext": "allow",
      "jupytext *": "allow",
      "cat *.ipynb": "deny"
    },
    "edit": "allow",
    "question": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "lsp": "allow"
  },
  "command": {},
  "watcher": {
    "ignore": []
  },
  "plugin": [],
  "instructions": [],
  "provider": {},
  "mcp": {},
  "formatter": true,
  "lsp": true,
  "experimental": {
    "disable_paste_summary": false
  }
}
